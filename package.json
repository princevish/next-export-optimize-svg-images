{
  "name": "next-export-optimize-svg-images",
  "version": "1.0.0",
  "description": "Optimize images and SVGs for Next.js static exports with responsive breakpoints and automatic format conversion.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "next-export-optimize-svg-images": "dist/cli/optimize.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/optimize.ts --format cjs,esm --dts --minify --clean --sourcemap",
    "dev": "tsup src/index.ts src/cli/optimize.ts --format cjs,esm --watch --dts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nextjs",
    "static-export",
    "image-optimization",
    "svg",
    "sharp",
    "svgo",
    "responsive-images"
  ],
  "author": {
    "name": "Prince Vishwakarma",
    "email": "princevworld@gmail.com",
    "url": "https://github.com/princevish"
  },
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/princevish/next-export-optimize-svg-images.git"
  },
  "bugs": {
    "url": "https://github.com/princevish/next-export-optimize-svg-images/issues"
  },
  "homepage": "https://github.com/princevish/next-export-optimize-svg-images#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
